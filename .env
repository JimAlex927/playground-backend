PLAYGROUND_NACOS_ENABLED=true
PLAYGROUND_NACOS_SERVER_ADDRS=http://127.0.0.1:8848
PLAYGROUND_NACOS_NAMESPACE_ID=
PLAYGROUND_NACOS_GROUP=DEFAULT_GROUP
PLAYGROUND_NACOS_DATA_ID=playground-backend.yaml
PLAYGROUND_NACOS_USERNAME=nacos
PLAYGROUND_NACOS_PASSWORD=nacos
PLAYGROUND_NACOS_FORMAT=yaml
PLAYGROUND_NACOS_TIMEOUT=5s
PLAYGROUND_NACOS_LOG_DIR=storage/nacos/log
PLAYGROUND_NACOS_CACHE_DIR=storage/nacos/cache
PLAYGROUND_AUTH_HTTP_ADDR=:8081
PLAYGROUND_APP_HTTP_ADDR=:8090
PLAYGROUND_DB_DRIVER=mysql
PLAYGROUND_DB_DSN=root:7777777@tcp(127.0.0.1:3306)/playground?parseTime=true&charset=utf8mb4&loc=Local
PLAYGROUND_DB_AUTO_MIGRATE=true
PLAYGROUND_DB_MAX_OPEN_CONNS=10
PLAYGROUND_DB_MAX_IDLE_CONNS=5
PLAYGROUND_DB_CONN_MAX_LIFETIME=30m
PLAYGROUND_TOKEN_SECRET=change-me-before-production
PLAYGROUND_CREDENTIAL_SECRET_KEY=change-me-before-production
PLAYGROUND_TOKEN_TTL=24h
PLAYGROUND_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost
PLAYGROUND_ALLOW_DIRECT_TOKEN=true
PLAYGROUND_LOG_LEVEL=info
PLAYGROUND_LOG_FORMAT=text
PLAYGROUND_LOG_STDOUT=true
PLAYGROUND_LOG_COLOR=true
PLAYGROUND_LOG_ADD_SOURCE=false
PLAYGROUND_LOG_FILE_ENABLED=false
PLAYGROUND_LOG_FILE_DIR=storage/logs
PLAYGROUND_LOG_FILE_DAILY_ROTATE=true
PLAYGROUND_BOOTSTRAP_ADMIN_USERNAME=admin
PLAYGROUND_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
PLAYGROUND_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
PLAYGROUND_BOOTSTRAP_ADMIN_DISPLAY_NAME=Playground Admin
PLAYGROUND_BOOTSTRAP_TENANT_ID=default
